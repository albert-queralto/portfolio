---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/nav.astro";
import Footer from "@/components/footer.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Blog — Albert Queraltó">
  <Nav />
  <main class="max-w-5xl mx-auto py-24 md:py-36 text-[var(--white)]">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">Writing</h2>
    <h1 class="text-4xl md:text-5xl font-medium mb-12">Blog</h1>
    <div class="flex flex-col gap-6">
      {
        posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group block rounded-2xl border border-[var(--white-icon-tr)] bg-[var(--card-bg)] p-6 hover:border-[var(--sec)] transition-colors duration-300"
          >
            <p class="text-xs text-[var(--white-icon)] mb-2">
              {post.data.date.toLocaleDateString("en-GB", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </p>
            <h3 class="text-xl font-semibold mb-2 group-hover:text-[var(--sec)] transition-colors">
              {post.data.title}
            </h3>
            <p class="text-sm text-[var(--white-icon)] mb-4">
              {post.data.description}
            </p>
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="text-xs px-2 py-1 rounded-md bg-[var(--white-icon-tr)] text-[var(--sec)]">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </main>
  <Footer />
</Layout>

<style is:global>
  .shiny-sec {
    background: linear-gradient(135deg, #76a8ff 25%, #e5f3ff 50%, #76c1ff 75%);
    background-size: 400% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: shine 3s linear infinite;
  }
  @keyframes shine {
    0% { background-position: 100% 50%; }
    30%, 70% { background-position: 0% 50%; }
  }
</style>
